        {
          "name": "Get Customer Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time is under 1000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "",
                  "let responseJson;",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "    responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.be.an('object');",
                  "});",
                  "",
                  "pm.test(\"User id exists and equals 1\", function () {",
                  "    pm.expect(responseJson).to.have.property('id');",
                  "    pm.expect(responseJson.id).to.be.a('number');",
                  "    pm.expect(responseJson.id).to.eql(1);",
                  "});",
                  "",
                  "pm.test(\"User firstName exists and is a non-empty string\", function () {",
                  "    pm.expect(responseJson).to.have.property('firstName');",
                  "    pm.expect(responseJson.firstName).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"User email exists and looks like an email\", function () {",
                  "    pm.expect(responseJson).to.have.property('email');",
                  "    pm.expect(responseJson.email).to.be.a('string').and.not.empty;",
                  "    pm.expect(responseJson.email).to.include('@');",
                  "});",
                  "",
                  "pm.test(\"User address exists and contains basic fields\", function () {",
                  "    pm.expect(responseJson).to.have.property('address');",
                  "    pm.expect(responseJson.address).to.be.an('object');",
                  "    pm.expect(responseJson.address).to.have.property('address');",
                  "    pm.expect(responseJson.address.address).to.be.a('string').and.not.empty;",
                  "    pm.expect(responseJson.address).to.have.property('city');",
                  "    pm.expect(responseJson.address.city).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
